# Server-only secret. Never expose this as NEXT_PUBLIC_* or commit a real value.
OPENAI_API_KEY=

# Optional override. V's defaults to the high-reliability model below.
OPENAI_MODEL=gpt-5.6-sol
OPENAI_BALANCED_MODEL=gpt-5.6-terra
OPENAI_FAST_MODEL=gpt-5.6-luna

# Optional Anthropic Claude connection and allowlisted model overrides.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_BALANCED_MODEL=claude-sonnet-5
ANTHROPIC_FAST_MODEL=claude-haiku-4-5

# Optional Google Gemini connection and allowlisted model overrides.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BALANCED_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite

# Optional comma-separated ChatGPT account emails allowed to use the server key.
# Leave blank to allow any authenticated visitor; set this before broad sharing.
AI_ALLOWED_EMAILS=

# Official LinkedIn OpenID Connect (identity only). Create an app at
# https://www.linkedin.com/developers/apps and enable "Sign In with LinkedIn using OpenID Connect".
# The redirect URI must exactly match your deployed site plus /api/linkedin/callback.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-site.example/api/linkedin/callback
# Generate at least 32 random characters. Never expose this as NEXT_PUBLIC_*.
LINKEDIN_SESSION_SECRET=
