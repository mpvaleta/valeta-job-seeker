{
  "manifest_version": 3,
  "name": "Valeta Application Autofill",
  "version": "0.1.0",
  "description": "Review-first autofill for job application forms. Never submits forms.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": { "default_popup": "popup.html", "default_title": "Valeta Autofill" },
  "content_scripts": [{ "matches": ["https://*/*"], "js": ["content.js"], "run_at": "document_idle" }]
}
